    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^5.22.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
