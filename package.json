{
  "name": "cleo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint:backend": "cd backend && npm run lint:check",
    "lint:frontend": "cd frontend && npm run lint:check",
    "typecheck:backend": "cd backend && npm run typecheck",
    "typecheck:frontend": "cd frontend && npm run typecheck",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "prepare": "husky"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
